PORT=3001
NODE_ENV=development

# Neon PostgreSQL — copy the "pooled connection" string from your Neon project dashboard
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Vercel Blob — generated automatically when you add Blob storage to your Vercel project
BLOB_READ_WRITE_TOKEN=vercelblob_rw_...

JWT_SECRET=replace-with-shared-secret-from-emre

EDEVLET_API_URL=http://localhost:3001/mocks/edevlet
OCR_PARSER_URL=http://localhost:3001/mocks/ocr

MOCK_AUTH_HEADER=x-mock-user
